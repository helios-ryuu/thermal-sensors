[Unit]
Description=Xuất nhiệt độ iMac đã chọn cho Prometheus
After=local-fs.target

[Service]
Type=oneshot
User=helios
Group=helios
ExecStart=/usr/bin/python3 /opt/thermal-monitoring/collector/collect_sensors.py
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/thermal-sensors/textfile

